# ===========================================
# NexT Theme Configuration
# ===========================================

# Menu - leave empty to use defaults
menu:
  home: / || home
  tags: /tags/ || tags
  categories: /categories/ || th
  archives: /archives/ || archive
  about: /about/ || user

# Favicon
favicon:
  small: /images/favicon.ico
  medium: /images/favicon.ico
  apple_touch_icon: /images/apple-touch-icon.png
  safari_pinned_tab: /images/logo.svg

# Logo
logo:
  enabled: true
  url: /images/logo.svg
  effect: true

# Creative Commons License
creative_commons:
  license: by-nc-sa
  sidebar: true
  post: true
  language: en_US

# ===========================================
# Scheme Settings - USE: Pisces / Gemini
# ===========================================
scheme: Pisces

# ===========================================
# Dark Mode
# ===========================================
darkmode: true

# ===========================================
# Background - 3D动效
# ===========================================
canvas_ribbon:
  enable: true
  size: 90
  alpha: 0.6
  zIndex: -1
  click_to_change: false
  motion: true

# ===========================================
# SEO
# ===========================================
sitemap:
  path: sitemap.xml
  template: ./sitemap.xml
  rel: false
  tags: true
  categories: true

# ===========================================
# Social Links
# ===========================================
social:
  GitHub: https://github.com/Oliver1025 || github
  Email: mailto:oliver@oliverleah.cn || envelope

social_icons:
  enable: true
  icons_only: false
  transition: false

# ===========================================
# Posts
# ===========================================
excerpt_description: true
read_more_btn: true

# Post meta
post_meta:
  item_scope: true
  itemprop_author: true
  created_at: true
  updated_at: false
  categories: true
  tags: true

# Post wordcount
post_wordcount:
  enable: true
  wordcount: true
  min2read: true
  separated_meta: true

# ===========================================
# Tags
# ===========================================
tag_page:
  enable: true
  sidebar: true

# ===========================================
# Categories
# ===========================================
category_page:
  enable: true
  sidebar: true

# ===========================================
# Footer
# ===========================================
footer:
  since: 2026
  copyright: Oliver

# ===========================================
# Comment
# ===========================================
comments:
  style: tabs
  enable: false
  lazyload: true
  count: false

# ===========================================
# Utilities
# ===========================================
external_url:
  enable: true
  field: site
  exclude: ''

# ===========================================
# Analytics
# ===========================================
google_analytics:
  enable: false
  id: ''
  async: true

# ===========================================
# Local Search
# ===========================================
local_search:
  enable: true
  preload: true
  trigger: auto
  top_n_per_article: 1
  unescape: false
  languages:
    home: Home
    posts: Posts
    tags: Tags
    categories: Categories
    ok: OK
    zero_results: No results
    results: Results
    emptied: We're sorry, no results found

# ===========================================
# Mobile
# ===========================================
mobile:
  enabled: true
  gemini: true

# ===========================================
# Chat
# ===========================================
chat:
  enable: false

# ===========================================
# Vendors
# ===========================================
vendors:
  plugins: cdnjs

# ===========================================
# Misc
# ===========================================
misc:
  language: en
